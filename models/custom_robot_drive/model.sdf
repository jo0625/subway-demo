<?xml version="1.0"?>
<sdf version="1.7">
  <model name="custom_robot_drive">
    <static>false</static>
    <self_collide>false</self_collide>

    <link name="base_footprint"/>

    <link name="base_link">
      <pose relative_to="base_footprint">0 0 0.08 0 0 0</pose>
      <inertial>
        <pose>0 0 0.04 0 0 0</pose>
        <mass>5.4</mass>
        <inertia>
          <ixx>0.16</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.18</iyy>
          <iyz>0</iyz>
          <izz>0.22</izz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <pose>0 0 0.06 0 0 0</pose>
        <geometry>
          <box>
            <size>0.62 0.58 0.16</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <kp>1e+06</kp>
              <kd>10</kd>
              <max_vel>0.1</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>

      <visual name="custom_body_visual">
        <!-- Imported mesh needs a roll flip to match the Gazebo Z-up preview. -->
        <pose>0 0 0.04 3.14159 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://custom_robot/meshes/base_link.STL</uri>
          </mesh>
        </geometry>
      </visual>

      <visual name="custom_yaw_visual">
        <pose>0 0 0.04 3.14159 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://custom_robot/meshes/yaw.STL</uri>
          </mesh>
        </geometry>
      </visual>

      <visual name="front_marker_visual">
        <pose>0.32 0 0.20 0 0 0</pose>
        <geometry>
          <box>
            <size>0.06 0.34 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.05 0.8 0.35 1</ambient>
          <diffuse>0.05 0.8 0.35 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="base_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
    </joint>

    <joint name="wheel_left_joint" type="revolute">
      <pose relative_to="base_footprint">0.18 0.18 0.05 0 0 0</pose>
      <parent>base_link</parent>
      <child>wheel_left_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
      </axis>
    </joint>

    <link name="wheel_left_link">
      <pose relative_to="wheel_left_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.18</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00045</iyy>
          <izz>0.00025</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>1e+06</kp>
              <kd>10</kd>
              <max_vel>0.1</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <visual name="visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="wheel_right_joint" type="revolute">
      <pose relative_to="base_footprint">0.18 -0.18 0.05 0 0 0</pose>
      <parent>base_link</parent>
      <child>wheel_right_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
      </axis>
    </joint>

    <link name="wheel_right_link">
      <pose relative_to="wheel_right_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.18</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00045</iyy>
          <izz>0.00025</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>1e+06</kp>
              <kd>10</kd>
              <max_vel>0.1</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <visual name="visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="wheel_left_rear_joint" type="revolute">
      <pose relative_to="base_footprint">-0.18 0.18 0.05 0 0 0</pose>
      <parent>base_link</parent>
      <child>wheel_left_rear_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
      </axis>
    </joint>

    <link name="wheel_left_rear_link">
      <pose relative_to="wheel_left_rear_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.18</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00045</iyy>
          <izz>0.00025</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="wheel_right_rear_joint" type="revolute">
      <pose relative_to="base_footprint">-0.18 -0.18 0.05 0 0 0</pose>
      <parent>base_link</parent>
      <child>wheel_right_rear_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
      </axis>
    </joint>

    <link name="wheel_right_rear_link">
      <pose relative_to="wheel_right_rear_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.18</mass>
        <inertia>
          <ixx>0.00025</ixx>
          <iyy>0.00045</iyy>
          <izz>0.00025</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <plugin name="custom_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
      </ros>
      <update_rate>50</update_rate>
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.36</wheel_separation>
      <wheel_diameter>0.10</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>3.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
      </ros>
      <update_rate>50</update_rate>
      <joint_name>wheel_left_joint</joint_name>
      <joint_name>wheel_right_joint</joint_name>
      <joint_name>wheel_left_rear_joint</joint_name>
      <joint_name>wheel_right_rear_joint</joint_name>
    </plugin>
  </model>
</sdf>

<?xml version="1.0"?>
<robot name="inspection_robot_with_lidar">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.22" rpy="0 0 0"/>
      <geometry>
        <box size="1.40 0.90 0.34"/>
      </geometry>
      <material name="blue">
        <color rgba="0.08 0.38 0.62 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.22" rpy="0 0 0"/>
      <geometry>
        <box size="1.40 0.90 0.34"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.22" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="0.92" ixy="0" ixz="0" iyy="1.85" iyz="0" izz="2.25"/>
    </inertial>
  </link>

  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.14" length="0.08"/>
      </geometry>
      <material name="black">
        <color rgba="0.02 0.02 0.02 1"/>
      </material>
    </visual>
  </link>
  <joint name="front_left_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.45 0.48 0.02" rpy="0 0 0"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.14" length="0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="front_right_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.45 -0.48 0.02" rpy="0 0 0"/>
  </joint>

  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.14" length="0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rear_left_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.45 0.48 0.02" rpy="0 0 0"/>
  </joint>

  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.14" length="0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rear_right_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.45 -0.48 0.02" rpy="0 0 0"/>
  </joint>

  <link name="sensor_mast">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.80"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.08 0.08 0.08 1"/>
      </material>
    </visual>
  </link>
  <joint name="sensor_mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_mast"/>
    <origin xyz="0 0 0.78" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.18" length="0.12"/>
      </geometry>
      <material name="lidar_black">
        <color rgba="0.01 0.01 0.01 1"/>
      </material>
    </visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="sensor_mast"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.46" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.18 0.10 0.10"/>
      </geometry>
      <material name="camera_black">
        <color rgba="0.02 0.02 0.02 1"/>
      </material>
    </visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.60 0 0.46" rpy="0 0 0"/>
  </joint>
</robot>
